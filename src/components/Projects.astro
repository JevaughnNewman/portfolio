---
import { siteConfig } from "../config";
import Tableau from "./Tableau.astro";

// We aren't using the projects loop right now to ensure the PBI embed works perfectly
---

<div id="projects" class="py-16 bg-white sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2
        class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl"
        style={`color: ${siteConfig.accentColor}`}
      >
        Projects
      </h2>
      <p class="mt-6 text-lg/8 text-gray-600">
        Professional data solutions delivering actionable insights and strategic recommendations.
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-2xl flex flex-col gap-y-16 lg:max-w-none">
      
      {/* 1. TARGET E-COMMERCE CARD */}
      <div class="flex flex-col rounded-lg overflow-hidden h-full shadow-lg border border-gray-100 bg-white transition-transform duration-300 hover:scale-[1.02]">
        <div class="w-full aspect-video bg-gray-100">
          <Tableau />
        </div>
        <div class="flex-1 w-full p-6 bg-white flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold text-gray-800">Target Ecommerce Executive Dashboard</h3>
            <p class="mt-4 text-gray-600 leading-relaxed">
              Utilized MySQL Workbench 8.0.40 to ingest and profile large-scale historical transaction ledgers, identifying operational bottlenecks and tracking transactional velocity across regional distributions. Executed complex relational queries and window functions to isolate anomalies in user verification data, behaviour variance, and customer settlement clusters. Developed a centralized Tableau analytics interface to map these geographic risk hot spots and identity profiles, transforming raw database logs into clear, operational indicators to support strategic fraud mitigation and threat control testing.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {["Tableau", "SQL", "MySQL Workbench 8.0.40"].map((skill) => (
                <span class="bg-gray-100 text-gray-700 text-xs px-3 py-1 rounded-full font-semibold border border-gray-200">{skill}</span>
              ))}
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-gray-100 flex flex-wrap items-center justify-between gap-4">
            <a href="https://github.com/JevaughnNewman/Target-E-Commerce-Sales-Data-Project" target="_blank" class="text-sm text-blue-600 font-bold hover:underline">
              View Project on GitHub →
            </a>
            <a href="https://drive.google.com/file/d/1s5hWhGe7MTcsArqwWXPTB3z-1-4T1acD/view?usp=sharing" 
              target="_blank" 
              class="text-sm text-gray-700 font-bold hover:text-blue-600 flex items-center gap-1"
            >
              Strategic Insights Deck ↗
            </a>
          </div>
        </div>
      </div>

      {/* 2. EAST COAST INSURANCE CARD (HARDCODED URL) */}
      <div class="flex flex-col rounded-lg overflow-hidden h-full shadow-lg border border-gray-100 bg-white transition-transform duration-300 hover:scale-[1.02]">
        <div class="w-full aspect-video bg-gray-100">
          <iframe
            class="w-full h-full border-0"
            src="https://app.powerbi.com/view?r=eyJrIjoiNGY2Y2Y4NDItYzBjNC00NWU3LWEyNjgtYjYyYmIyOWQwYzNkIiwidCI6IjVhMmY2ZmQxLTU3MzctNGY3Ny04MmNkLWQ4MGNhMGNkZjZiYSJ9"
            allowfullscreen="true"
            loading="lazy"
          ></iframe>
        </div>
        <div class="flex-1 w-full p-6 bg-white flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold text-gray-800">Insurance Claims Anomaly Engine Q1, East Coast Insurance</h3>
            <p class="mt-4 text-gray-600 leading-relaxed">
              Engineered a relational star-schema data model in Microsoft SQL Server 2022 to unify fragmented, multi-source claims and customer logging records. Designed and executed complex relational queries to backtest historical transaction trends, profiling high-risk claimant demographics and identifying underlying injury pattern anomalies. Delivered an interactive Power BI analytics environment that isolated systemic billing variances, providing risk operations with the auditable insights required to plug leakage and mitigate future portfolio exposure.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {["Power BI", "SQL", "MS SQL Server 2022"].map((skill) => (
                <span class="bg-gray-100 text-gray-700 text-xs px-3 py-1 rounded-full font-semibold border border-gray-200">{skill}</span>
              ))}
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-gray-100 flex flex-wrap items-center justify-between gap-4">
            <a href="https://github.com/JevaughnNewman/East-Coast-Insurance-Data-Project" target="_blank" class="text-sm text-blue-600 font-bold hover:underline">
              View Project on GitHub →
            </a>
            <a href="https://drive.google.com/file/d/1ggO2668AlgaP4a1pyw95dvCNKtfYxRO0/view?usp=sharing" target="_blank" class="text-sm text-gray-700 font-bold hover:text-blue-600 flex items-center gap-1"
            >
              Executive Briefing Deck ↗
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
